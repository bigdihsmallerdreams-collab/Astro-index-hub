-- TAB SWITCHING
-- ============================================
local function switchTab(tab)
    if tab == "SPAMMER" then
        tweenButton(SpammerBtn, SpammerStroke, true)
        tweenButton(DefenderBtn, DefenderStroke, false)
        SpammerPanel.Visible = true
        DefenderPanel.Visible = false
        refreshPlayerList()
    else
        tweenButton(DefenderBtn, DefenderStroke, true)
        tweenButton(SpammerBtn, SpammerStroke, false)
        DefenderPanel.Visible = true
        SpammerPanel.Visible = false
    end
end

