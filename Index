local ACTIVE = {
    BackgroundColor3 = Color3.fromRGB(0, 80, 200),
    TextColor3 = Color3.fromRGB(255, 255, 255),
    StrokeColor = Color3.fromRGB(0, 150, 255),
    StrokeTransparency = 0,
}
local INACTIVE = {
    BackgroundColor3 = Color3.fromRGB(20, 20, 30),
    TextColor3 = Color3.fromRGB(120, 120, 160),
    StrokeColor = Color3.fromRGB(0, 40, 120),
    StrokeTransparency = 0.6,
}
local TWEEN_INFO = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function tweenButton(btn, stroke, active)
    local state = active and ACTIVE or INACTIVE
    TweenService:Create(btn, TWEEN_INFO, {
        BackgroundColor3 = state.BackgroundColor3,
        TextColor3 = state.TextColor3,
    }):Play()
    if stroke then
        TweenService:Create(stroke, TWEEN_INFO, {
            Color = state.StrokeColor,
            Transparency = state.StrokeTransparency,
        }):Play()
    end
end

